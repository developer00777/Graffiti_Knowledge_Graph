# Email Knowledge Graph Configuration
# =====================================
# Copy this file to .env and fill in your values

# OpenRouter API (OpenAI-compatible endpoint)
# Get your API key from: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Recommended models via OpenRouter:
# - anthropic/claude-sonnet-4 (best for extraction)
# - openai/gpt-4o-mini (fast and cheap)
# - google/gemini-2.0-flash-exp (good balance)
MODEL_NAME=anthropic/claude-sonnet-4

# Neo4j Database
# Default credentials for local Docker instance
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Google Workspace (Gmail)
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_EMAIL=

# Microsoft 365 (Outlook) - Optional
# Register app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_USER_EMAIL=

# Your company's email domains (comma-separated)
# Used to identify internal team members vs external contacts
TEAM_DOMAINS=yourcompany.com

# WhatsApp Assistant Integration (Optional)
# Endpoint where the CEO WhatsApp assistant can query this service
API_HOST=0.0.0.0
API_PORT=8080

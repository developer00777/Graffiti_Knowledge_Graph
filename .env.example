# CHAMP Graph Configuration
# =========================
# Copy this file to .env and fill in your values

# ---- API Authentication ----
# When set, all API requests (except /health) require X-API-Key header.
# Leave empty for development (auth disabled).
CHAMP_GRAPH_API_KEY=

# ---- LLM Provider (OpenAI-compatible) ----
# OpenRouter is the default. Any OpenAI-compatible endpoint works.
# Get your API key from: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Recommended models via OpenRouter:
# - openai/gpt-4.1-nano (fast and cheap)
# - anthropic/claude-sonnet-4 (best for extraction)
# - google/gemini-2.0-flash-exp (good balance)
MODEL_NAME=openai/gpt-4.1-nano

# ---- Neo4j Database ----
# Docker Compose uses these for both neo4j service and the API.
# For Railway: point NEO4J_URI to your provisioned Neo4j instance.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ---- Google Workspace (Gmail) ----
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_EMAIL=

# ---- Microsoft 365 (Outlook) ----
# Register app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_USER_EMAIL=

# ---- Embedding Provider (OpenAI-compatible) ----
EMBEDDING_MODEL=openai/text-embedding-3-small
# Override these to use a different key/endpoint for embeddings (defaults to OPENAI_* values):
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=

# ---- Team Configuration ----
# Your company's email domains (comma-separated).
# Used to identify internal team members vs external contacts.
TEAM_DOMAINS=yourcompany.com

# ---- API Server ----
API_HOST=0.0.0.0
API_PORT=8080
# Comma-separated allowed CORS origins. Leave empty to allow all (development only).
# Example: CORS_ORIGINS=https://myapp.com,https://staging.myapp.com
CORS_ORIGINS=
